# .env.example - Copy this to .env and fill in your values
# Only active and utilized configuration variables are listed below.

# =============================================================================
# CORE SETTINGS
# =============================================================================
DEBUG=True
ENVIRONMENT=development
SECRET_KEY=your-super-secret-key-change-this-in-production-min-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
SITE_URL=http://localhost:8000
SITE_NAME=Harbour Hub
FRONTEND_URL=http://localhost:3000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=
DB_NAME=harbour_hub
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=600

# =============================================================================
# REDIS & CELERY CONFIGURATION
# =============================================================================
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CACHE_TIMEOUT=3600
CACHE_KEY_PREFIX=harbour_hub

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@harbourhubglobal.com
SERVER_EMAIL=server@harbourhubglobal.com
ADMIN_EMAIL=admin@harbourhubglobal.com
SUPPORT_EMAIL=support@harbourhubglobal.com
SECURITY_EMAIL=security@harbourhubglobal.com
SEND_WELCOME_EMAIL=True

# =============================================================================
# PAYSTACK
# =============================================================================
PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=your-paystack-public-key
PAYSTACK_CALLBACK_URL=http://localhost:3000/payment/callback

# =============================================================================
# FILE STORAGE CONFIGURATION (AWS S3)
# =============================================================================
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=harbour-hub-storage
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=harbour-hub-storage.s3.amazonaws.com
MEDIA_ROOT=media
STATIC_ROOT=staticfiles

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001
CORS_ALLOW_ALL_ORIGINS=False
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_ACCESS_TOKEN_LIFETIME_HOURS=24
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=True
PASSWORD_MIN_LENGTH=8

# =============================================================================
# RATE LIMITING & API CONFIGURATION
# =============================================================================
RATELIMIT_ENABLE=True
RATELIMIT_IP_META_KEY=HTTP_X_FORWARDED_FOR
DEFAULT_PAGE_SIZE=20
API_RATE_LIMIT=1000/hour
API_BURST_LIMIT=100/minute
API_TITLE=Harbour Hub API
API_VERSION=1.0.0

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/harbour_hub.log
LOG_MAX_SIZE_MB=100
LOG_BACKUP_COUNT=5

# =============================================================================
# MONITORING & PERFORMANCE
# =============================================================================
ENABLE_DEBUG_TOOLBAR=True
ENABLE_DJANGO_EXTENSIONS=True
SENTRY_DSN=
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

# =============================================================================
# HTTPS / HSTS (Production overrides)
# =============================================================================
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False