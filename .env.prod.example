# .env.prod.example - Production environment configuration
# Copy this to .env.prod and fill in your production values

# =============================================================================
# CORE SETTINGS
# =============================================================================
DEBUG=False
ENVIRONMENT=production
SECRET_KEY=your-production-secret-key-minimum-50-characters-long-and-random
ALLOWED_HOSTS=harbourhub.com,www.harbourhub.com,api.harbourhub.com
SITE_URL=https://harbourhub.com
SITE_NAME=Harbour Hub
FRONTEND_URL=https://app.harbourhub.com

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://harbour_hub_user:secure_password@your-db-host:5432/harbour_hub_prod
DB_NAME=harbour_hub_prod
DB_USER=harbour_hub_user
DB_PASSWORD=your_secure_db_password
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=600

# =============================================================================
# REDIS & CELERY CONFIGURATION
# =============================================================================
REDIS_URL=redis://your-redis-host:6379/1
CELERY_BROKER_URL=redis://your-redis-host:6379/1
CELERY_RESULT_BACKEND=redis://your-redis-host:6379/2
CACHE_TIMEOUT=3600
CACHE_KEY_PREFIX=harbour_hub

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-production-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-app-password
DEFAULT_FROM_EMAIL=Harbour Hub <noreply@harbourhubglobal.com>
SERVER_EMAIL=server@harbourhubglobal.com
ADMIN_EMAIL=admin@harbourhubglobal.com
SUPPORT_EMAIL=support@harbourhubglobal.com
SECURITY_EMAIL=security@harbourhubglobal.com
SEND_WELCOME_EMAIL=True

# =============================================================================
# PAYSTACK
# =============================================================================
PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=your-paystack-public-key
PAYSTACK_CALLBACK_URL=https://app.harbourhub.com/payment/callback

# =============================================================================
# FILE STORAGE CONFIGURATION (AWS S3)
# =============================================================================
USE_S3=True
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=harbour-hub-production-storage
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=harbour-hub-production-storage.s3.amazonaws.com
MEDIA_ROOT=media
STATIC_ROOT=staticfiles

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
CORS_ALLOWED_ORIGINS=https://harbourhub.com,https://app.harbourhub.com
CORS_ALLOW_ALL_ORIGINS=False
CSRF_TRUSTED_ORIGINS=https://harbourhub.com,https://app.harbourhub.com
JWT_ACCESS_TOKEN_LIFETIME_HOURS=24
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=True
PASSWORD_MIN_LENGTH=8

# =============================================================================
# RATE LIMITING & API CONFIGURATION
# =============================================================================
RATELIMIT_ENABLE=True
RATELIMIT_IP_META_KEY=HTTP_X_FORWARDED_FOR
DEFAULT_PAGE_SIZE=20
API_RATE_LIMIT=1000/hour
API_BURST_LIMIT=100/minute
API_TITLE="Harbour Hub API"
API_VERSION=v1

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=WARNING
LOG_FILE_PATH=logs/harbour_hub.log
LOG_MAX_SIZE_MB=100
LOG_BACKUP_COUNT=5

# =============================================================================
# MONITORING & PERFORMANCE
# =============================================================================
ENABLE_DEBUG_TOOLBAR=False
ENABLE_DJANGO_EXTENSIONS=False
SENTRY_DSN=https://your-sentry-dsn@o123456.ingest.sentry.io/123456789
POSTHOG_PROJECT_API_KEY=your-posthog-project-api-key
POSTHOG_HOST=https://eu.i.posthog.com

# =============================================================================
# HTTPS / HSTS (Production overrides)
# =============================================================================
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True